# =============================================================================
# RepoPilot — Environment Configuration Template
# =============================================================================

# 1. Choose your Inference Backend: "dashscope" (Qwen Cloud), "sglang" (Modal), or "vllm" (custom/local)
BACKEND_TYPE=dashscope

# 2. Base Model Name (e.g., Qwen/Qwen2.5-7B-Instruct, Qwen/Qwen2.5-Coder-32B-Instruct)
MODEL_NAME=Qwen/Qwen2.5-7B-Instruct

# -----------------------------------------------------------------------------
# BACKEND SPECIFIC KEYS
# -----------------------------------------------------------------------------

# Option A: DashScope (Qwen Cloud Services) - Required if BACKEND_TYPE=dashscope
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Option B: Modal SGLang / vLLM Deployment - Required if BACKEND_TYPE=sglang
MODAL_ENDPOINT_URL=https://your-modal-app-endpoint.modal.run/v1

# Option C: OpenAI / Custom vLLM Endpoint - Required if BACKEND_TYPE=vllm
OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=http://localhost:8000/v1
